rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function canManageFriendEdge(userId, friendId) {
      return isSignedIn()
        && (request.auth.uid == userId || request.auth.uid == friendId);
    }

    function isSessionParticipant() {
      return isSignedIn()
        && request.auth.uid in resource.data.participantIds;
    }

    function isNewSessionParticipant() {
      return isSignedIn()
        && request.auth.uid in request.resource.data.participantIds;
    }

    function isParticipantInSession(sessionId) {
      return isSignedIn()
        && request.auth.uid in get(
          /databases/$(database)/documents/shared_sessions/$(sessionId)
        ).data.participantIds;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /profile/{document=**} {
        allow read, write: if isOwner(userId);
      }

      match /friends/{friendId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if canManageFriendEdge(userId, friendId);
      }

      match /focuses/{focusId} {
        allow read, write: if isOwner(userId);

        match /sessions/{sessionId} {
          allow read, write: if isOwner(userId);
        }
      }
    }

    match /public_profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /shared_sessions/{sessionId} {
      allow create: if isNewSessionParticipant();
      allow read, update, delete: if isSessionParticipant();

      match /notes/{noteId} {
        allow read, write: if isParticipantInSession(sessionId);
      }
    }
  }
}
